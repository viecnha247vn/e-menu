// Vercel Serverless Function — nhận đơn từ menu (cùng origin) rồi chuyển sang Apps Script.
// Máy chủ gọi máy chủ => không CORS, không bị điện thoại chặn.

const APPS_SCRIPT_URL =
  'https://script.google.com/macros/s/AKfycbyOpDWKCwODMEMDtPxMGJ66mYvChgGGmIHe8HN-zNHEfdBLd4DobVs0uufEOXfKmrhY/exec';

export default async function handler(req, res) {
  if (req.method !== 'POST') {
    res.status(405).json({ ok: false, error: 'method' });
    return;
  }
  try {
    // body có thể là object (Vercel tự parse) hoặc chuỗi
    const payload = typeof req.body === 'string' ? JSON.parse(req.body || '{}') : (req.body || {});
    const data = encodeURIComponent(JSON.stringify(payload));
    const url = APPS_SCRIPT_URL + '?do=order&data=' + data;

    // gọi sang Apps Script từ phía máy chủ (theo trọn chuyển hướng, ghi Sheet + Telegram)
    const r = await fetch(url, { method: 'GET' });
    await r.text().catch(() => {});

    res.status(200).json({ ok: true });
  } catch (e) {
    res.status(200).json({ ok: false, error: String(e) });
  }
}
